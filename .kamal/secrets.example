# Kamal secrets - copy to .kamal/secrets and fill in values
# DO NOT commit the actual secrets file!

# Server IP (droplet)
SERVER_IP=YOUR_SERVER_IP

# Domain or IP for the app (used by kamal-proxy and PHX_HOST)
# Use IP for initial testing, switch to domain later
APP_HOST=YOUR_SERVER_IP
PHX_HOST=YOUR_SERVER_IP

# DigitalOcean Container Registry
# Use a DO API token with "Container Registry" scope
# Same token for both username and password
REGISTRY_URL=registry.digitalocean.com/YOUR_REGISTRY_NAME
KAMAL_REGISTRY_USERNAME=dop_v1_YOUR_API_TOKEN
KAMAL_REGISTRY_PASSWORD=dop_v1_YOUR_API_TOKEN

# PostgreSQL password
POSTGRES_PASSWORD=your-secure-postgres-password

# Database URL - uses container name as host (replicant-server-db)
DATABASE_URL=ecto://replicant:your-secure-postgres-password@replicant-server-db:5432/replicant_server_prod

# Phoenix secret key base - generate with: mix phx.gen.secret
SECRET_KEY_BASE=generate-with-mix-phx-gen-secret
